# ── Client-side (bundled into JS — never put secrets here) ───────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SENTRY_DSN=your_sentry_dsn_here

# ── Server-side only (never prefix with VITE_) ────────────────────────────────
# Supabase admin key — bypasses RLS. Python scripts + Vercel env vars only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic — Edge Function api/generate-scout-report.ts
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend — Edge Function api/send-invitation.ts
RESEND_API_KEY=your_resend_api_key

# Sentry source map uploads — build-time only (CI / Vercel build env)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# API-Football — Python import scripts only
API_FOOTBALL_KEY=your_api_football_key

# football-data.org — Edge Function api/get-fixtures.ts (upcoming matches)
# Free account at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key

# Stripe — payments & subscriptions
VITE_STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# Cron jobs — nightly data pipeline (Vercel Cron)
# Vercel automatically injects this as Authorization: Bearer $CRON_SECRET on cron calls
CRON_SECRET=your_random_cron_secret_here
# Production URL (without https://) — used by crons to call internal endpoints
# Vercel sets VERCEL_PROJECT_PRODUCTION_URL automatically; set APP_URL for local testing
APP_URL=scout-intelligence-ten.vercel.app
